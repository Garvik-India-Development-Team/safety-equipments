# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=safety_equipment

# Optional: base URL for server-side fetches (e.g. https://yoursite.com)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Contact / WhatsApp (shown in header and footer)
